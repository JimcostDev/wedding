---
// Footer.astro
interface Props {
  footer?: {
    names?: { left?: string; right?: string };
    dateLine?: string;
    placeLine?: string;
    thanksMessage?: string;
    bibleQuote?: { quote?: string; cite?: string };
    copyright?: string;
    madeWith?: string;
  };
}

const { footer } = Astro.props;
---

{/* Fondo un poco más oscuro (Stone-100/200) para "cerrar" visualmente la web */}
<footer class="bg-gradient-to-b from-slate-50 to-stone-200 py-16 md:py-24 relative overflow-hidden">

  <div class="max-w-3xl mx-auto px-6 relative z-10 text-center">
    
    {/* 1. NOMBRES Y CORAZÓN (El gran cierre) */}
    <div class="flex flex-col md:flex-row items-center justify-center gap-2 md:gap-6 mb-8">
      <span 
        class="text-6xl md:text-7xl lg:text-8xl text-stone-800 leading-none"
        style="font-family: 'Great Vibes', cursive;"
      >
        {footer?.names?.left}
      </span>
      
      <div class="py-2 md:py-0">
        <span class="icon-[mdi--heart] w-8 h-8 md:w-10 md:h-10 text-lime-800 animate-pulse"></span>
      </div>
      
      <span 
        class="text-6xl md:text-7xl lg:text-8xl text-stone-800 leading-none"
        style="font-family: 'Great Vibes', cursive;"
      >
        {footer?.names?.right}
      </span>
    </div>

    {/* 2. FECHA Y LUGAR (Minimalista) */}
    <div class="space-y-2 mb-12">
      <p 
        class="text-xl md:text-2xl text-stone-700 tracking-wider uppercase"
        style="font-family: 'Playfair Display', serif;"
      >
        {footer?.dateLine}
      </p>
      <p 
        class="text-sm md:text-base text-stone-500 font-medium tracking-[0.2em] uppercase"
        style="font-family: 'Montserrat', sans-serif;"
      >
        {footer?.placeLine}
      </p>
    </div>

    {/* 3. MENSAJE DE AGRADECIMIENTO (Sencillo) */}
    <p 
      class="text-lg md:text-xl text-stone-600 mb-16 font-light italic"
      style="font-family: 'Playfair Display', serif;"
    >
      {footer?.thanksMessage}
    </p>

    {/* 4. VERSÍCULO BÍBLICO (Sin caja, estilo editorial limpio) */}
    <div class="relative mb-16 px-4 md:px-10">
      {/* Icono Biblia decorativo sutil */}
      <div class="flex justify-center mb-4 opacity-40">
        <span class="icon-[bx--bible] w-8 h-8 text-stone-400"></span>
      </div>
      
      <blockquote class="relative">
        <p 
          class="text-lg md:text-xl text-stone-700 italic leading-relaxed font-light"
          style="font-family: 'Playfair Display', serif;"
        >
        {footer?.bibleQuote?.quote}
        </p>
        <footer class="mt-4">
          <cite 
            class="text-xs font-bold text-lime-800 tracking-widest uppercase not-italic"
            style="font-family: 'Montserrat', sans-serif;"
          >
          {footer?.bibleQuote?.cite}
          </cite>
        </footer>
      </blockquote>
    </div>

    {/* 5. COPYRIGHT (Discreto) */}
    <div class="border-t border-stone-300/50 pt-8 space-y-2">
      <p class="text-stone-400 text-xs font-medium tracking-wide" style="font-family: 'Montserrat', sans-serif;">
        {footer?.copyright}
      </p>
      <p class="text-stone-500 text-xs mt-2 italic flex items-center justify-center gap-1" style="font-family: 'Playfair Display', serif;">
        {footer?.madeWith}
      </p>
    </div>

  </div>
</footer>