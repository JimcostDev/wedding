---
// Header.astro
interface Props {
  hero?: {
    topText?: string;
    gallery?: Array<{
      imageSrc?: string;
      alt?: string;
      dateNumber?: string;
    }>;
    names?: string;
    bottomText?: string;
  };
}

const { hero } = Astro.props;
---

<header class="relative min-h-screen flex flex-col items-center justify-center py-20 overflow-hidden bg-slate-50">
  
  {/* 1. TEXTO SUPERIOR: NOS CASAMOS */}
  <p 
    class="text-xs md:text-sm text-lime-800 font-semibold tracking-[0.4em] uppercase mb-10 md:mb-16 animate-fade-in-down"
    style="font-family: 'Montserrat', sans-serif;"
  >
    {hero?.topText}
  </p>

  {/* 2. CONTENEDOR DE FOTOS Y FECHA */}
  <div class="w-full max-w-5xl mx-auto px-4 mb-16 md:mb-20 animate-fade-in">
    {/* Grid de 3 columnas para las fotos */}
    <div class="grid grid-cols-3 gap-2 md:gap-6 lg:gap-8">
      {hero?.gallery?.map((item, index) => {
        const isThird = index === 2;
        const overlayBase = isThird ? "bg-stone-900/10" : "bg-stone-900/30";
        const overlayHover = isThird ? "group-hover:bg-stone-900/30" : "group-hover:bg-stone-900/40";
        return (
          <div class="relative overflow-hidden aspect-[3/4] group rounded-xl md:rounded-2xl shadow-md">
            <img
              src={item?.imageSrc}
              alt={item?.alt}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000 ease-out"
            />
            <div class={`absolute inset-0 ${overlayBase} ${overlayHover} transition-colors duration-500`}></div>
            <div class="absolute inset-0 flex items-end justify-center pb-4 md:pb-6 pointer-events-none">
              <span class="date-number">{item?.dateNumber}</span>
            </div>
          </div>
        );
      })}
    </div>
  </div>

  {/* 3. NOMBRES (Firma) */}
  <h1 
    class="text-5xl sm:text-7xl text-stone-800 mb-8 md:mb-10 text-center animate-fade-in-up"
    style="font-family: 'Great Vibes', cursive;"
  >
    {hero?.names}
  </h1>

  {/* 4. TEXTO INFERIOR */}
  <div class="max-w-2xl mx-auto px-6 text-center animate-fade-in-up delay-200">
    <p 
      class="text-lg md:text-xl text-stone-500 italic leading-relaxed font-light"
      style="font-family: 'Playfair Display', serif;"
    >
      {hero?.bottomText}
    </p>
  </div>

</header>

<style>
  /* Estilo para los números gigantes sobre las fotos */
  .date-number {
    font-family: 'Playfair Display', serif;
    font-weight: 400;
    color: white;
    /* Tamaño fluido: se adapta mágicamente a cualquier pantalla */
    font-size: clamp(4rem, 13vw, 9rem); 
    line-height: 0.8; /* Reducimos un poco el interlineado para que no ocupe tanto hacia arriba */
    text-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
  }

  /* Animaciones suaves */
  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes fade-in-down {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .animate-fade-in { animation: fade-in 1.5s ease-out forwards; }
  .animate-fade-in-down { animation: fade-in-down 1.2s ease-out forwards; }
  .animate-fade-in-up { animation: fade-in-up 1.2s ease-out forwards; }
  .delay-200 { animation-delay: 0.3s; }
</style>