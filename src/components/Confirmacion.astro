---
import Title from "./Title.astro";

interface Props {
  rsvp?: {
    title?: string;
    subtitle?: string;
    confirmButton?: {
      text?: string;
      url?: string;
    };
    deadline?: {
      prefix?: string;
      dateBold?: string;
    };
  };
  gifts?: {
    title?: string;
    subtitle?: string;
    bizum?: {
      title?: string;
      copyText?: string;
      toRonaldoLabel?: string;
      toRonaldoValue?: string;
      toPaulaLabel?: string;
      toPaulaValue?: string;
    };
    transfer?: {
      title?: string;
      label?: string;
      ibanValue?: string;
      copyText?: string;
    };
    notes?: {
      label?: string;
      text?: string;
    };
    copyUi?: {
      successText?: string;
      errorAlertText?: string;
    };
  };
}

const { rsvp, gifts } = Astro.props;
---

<section class="py-16 md:py-24 bg-slate-50">
  <div class="max-w-6xl mx-auto px-4">

    <div class="mb-20 md:mb-28">
      <div class="text-center">
        <Title>{rsvp?.title}</Title>
        <p 
          class="text-stone-500 text-lg md:text-xl mt-4 mb-8 italic"
          style="font-family: 'Playfair Display', serif;"
        >
          {rsvp?.subtitle}
        </p>
        
        <a
          href={rsvp?.confirmButton?.url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 bg-linear-to-r from-lime-800 to-lime-900 hover:from-lime-900 hover:to-lime-950 text-white px-10 md:px-14 py-4 md:py-5 rounded-full transition-all duration-300 shadow-lg hover:shadow-xl transform hover:scale-105 font-medium text-lg md:text-xl group tracking-wide"
          style="font-family: 'Montserrat', sans-serif;"
        >
          <span class="icon-[hugeicons--party] w-6 h-6"></span>
          <span>{rsvp?.confirmButton?.text}</span>
        </a>
        
        <p class="mt-8 text-lime-800 font-medium text-sm md:text-base tracking-wide flex items-center justify-center gap-2" style="font-family: 'Montserrat', sans-serif;">
          <span class="icon-[tabler--calendar] w-5 h-5"></span>
          <span>
            {rsvp?.deadline?.prefix}
            <span class="font-bold">{rsvp?.deadline?.dateBold}</span>
          </span>
        </p>
      </div>
    </div>

    <div>
      <div class="text-center mb-12 md:mb-16">
        <Title>{gifts?.title}</Title>
        <p 
          class="text-stone-500 text-lg md:text-xl mt-4 italic"
          style="font-family: 'Playfair Display', serif;"
        >
          {gifts?.subtitle}
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 md:gap-10 lg:gap-12">

        <div class="group bg-white rounded-2xl border border-stone-200 overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
          <div class="bg-stone-50 p-6 md:p-8 border-b border-stone-100">
            <div class="flex items-center justify-center mb-4">
              <div class="w-14 h-14 bg-linear-to-br from-lime-700 to-lime-800 rounded-full flex items-center justify-center shadow-md">
                <span class="icon-[hugeicons--euro-send] w-7 h-7 text-white"></span>
              </div>
            </div>
            <h3 class="text-2xl md:text-3xl text-stone-800 text-center" style="font-family: 'Playfair Display', serif;">
              {gifts?.bizum?.title}
            </h3>
          </div>

          <div class="p-6 md:p-8 space-y-6">
            <div class="space-y-2">
              <label class="text-xs font-bold text-lime-800 uppercase tracking-widest block mb-1" style="font-family: 'Montserrat', sans-serif;">
                {gifts?.bizum?.toRonaldoLabel}
              </label>
              <button 
                class="w-full copy-btn bg-stone-50 border border-stone-200 hover:border-lime-600 text-stone-800 px-4 py-3 rounded-lg transition-all duration-300 font-mono text-lg tracking-wide font-medium group/btn hover:bg-white flex items-center justify-between"
                data-clipboard-text={gifts?.bizum?.toRonaldoValue}
              >
                <span>{gifts?.bizum?.toRonaldoValue}</span>
                <span
                  data-copy-label
                  data-success-text={gifts?.copyUi?.successText ?? "✅ ¡Listo!"}
                  data-error-text={gifts?.copyUi?.errorAlertText ?? "Error al copiar, por favor selecciona manualmente"}
                  class="text-xs uppercase bg-stone-200 px-2 py-1 rounded text-stone-600 group-hover/btn:bg-lime-100 group-hover/btn:text-lime-800 transition-colors flex-shrink-0"
                  title={gifts?.bizum?.copyText}
                  aria-label={gifts?.bizum?.copyText}
                >
                  <span class="icon-[tabler--copy] w-4 h-4 inline-block"></span>
                </span>
              </button>
            </div>

            <div class="space-y-2">
              <label class="text-xs font-bold text-lime-800 uppercase tracking-widest block mb-1" style="font-family: 'Montserrat', sans-serif;">
                {gifts?.bizum?.toPaulaLabel}
              </label>
              <button 
                class="w-full copy-btn bg-stone-50 border border-stone-200 hover:border-lime-600 text-stone-800 px-4 py-3 rounded-lg transition-all duration-300 font-mono text-lg tracking-wide font-medium group/btn hover:bg-white flex items-center justify-between"
                data-clipboard-text={gifts?.bizum?.toPaulaValue}
              >
                <span>{gifts?.bizum?.toPaulaValue}</span>
                <span
                  data-copy-label
                  data-success-text={gifts?.copyUi?.successText ?? "✅ ¡Listo!"}
                  data-error-text={gifts?.copyUi?.errorAlertText ?? "Error al copiar, por favor selecciona manualmente"}
                  class="text-xs uppercase bg-stone-200 px-2 py-1 rounded text-stone-600 group-hover/btn:bg-lime-100 group-hover/btn:text-lime-800 transition-colors flex-shrink-0"
                  title={gifts?.bizum?.copyText}
                  aria-label={gifts?.bizum?.copyText}
                >
                  <span class="icon-[tabler--copy] w-4 h-4 inline-block"></span>
                </span>
              </button>
            </div>
          </div>
        </div>

        <div class="group bg-white rounded-2xl border border-stone-200 overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
          <div class="bg-stone-50 p-6 md:p-8 border-b border-stone-100">
            <div class="flex items-center justify-center mb-4">
              <div class="w-14 h-14 bg-linear-to-br from-lime-700 to-lime-800 rounded-full flex items-center justify-center shadow-md">
                <span class="icon-[ion--card] w-7 h-7 text-white"></span>
              </div>
            </div>
            <h3 class="text-2xl md:text-3xl text-stone-800 text-center" style="font-family: 'Playfair Display', serif;">
              {gifts?.transfer?.title}
            </h3>
          </div>

          <div class="p-6 md:p-8 space-y-4">
            <p class="text-sm text-stone-500 text-center font-serif italic">
              {gifts?.transfer?.label}
            </p>
            <button 
              class="w-full copy-btn bg-stone-50 border border-stone-200 hover:border-lime-600 text-stone-800 px-4 py-4 rounded-lg transition-all duration-300 font-mono text-base md:text-lg tracking-wide font-medium group/btn hover:bg-white flex items-center justify-between gap-2"
              data-clipboard-text={gifts?.transfer?.ibanValue}
            >
              <span class="truncate">{gifts?.transfer?.ibanValue}</span>
              <span
                data-copy-label
                data-success-text={gifts?.copyUi?.successText ?? "✅ ¡Listo!"}
                data-error-text={gifts?.copyUi?.errorAlertText ?? "Error al copiar, por favor selecciona manualmente"}
                class="text-xs uppercase bg-stone-200 px-2 py-1 rounded text-stone-600 group-hover/btn:bg-lime-100 group-hover/btn:text-lime-800 transition-colors flex-shrink-0"
                title={gifts?.transfer?.copyText}
                aria-label={gifts?.transfer?.copyText}
              >
                <span class="icon-[tabler--copy] w-4 h-4 inline-block"></span>
              </span>
            </button>
          </div>
        </div>
      </div>

      <div class="mt-16 flex justify-center">
        <div class="bg-white border border-lime-800/20 rounded-full px-8 py-4 shadow-sm">
          <p class="text-sm md:text-base text-stone-600 font-sans">
            <span class="font-bold text-lime-800">{gifts?.notes?.label}</span> {gifts?.notes?.text}
          </p>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    async function copyToClipboard(text) {
      if (navigator.clipboard?.writeText) {
        return navigator.clipboard.writeText(text);
      }

      const textarea = document.createElement('textarea');
      textarea.value = text;
      textarea.setAttribute('readonly', '');
      textarea.style.position = 'fixed';
      textarea.style.left = '-9999px';
      document.body.appendChild(textarea);
      textarea.focus();
      textarea.select();
      textarea.setSelectionRange(0, textarea.value.length);
      document.execCommand('copy');
      document.body.removeChild(textarea);
    }

    document.querySelectorAll('.copy-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const text = btn.dataset.clipboardText;
        const actionSpan = btn.querySelector('[data-copy-label]');
        const originalInnerHTML = actionSpan?.innerHTML ?? '';
        const originalTitle = actionSpan?.getAttribute('title') ?? '';
        const originalClasses = actionSpan?.className ?? '';
        const SUCCESS_TEXT = actionSpan?.dataset.successText ?? "✅ ¡Listo!";
        const ERROR_TEXT = actionSpan?.dataset.errorText ?? "Error al copiar, por favor selecciona manualmente";

        try {
          if (!text) throw new Error("Missing clipboard text");
          await copyToClipboard(text);

          if (actionSpan) {
            actionSpan.className = "text-xs uppercase bg-lime-800 text-white px-2 py-1 rounded font-bold transition-colors flex-shrink-0";
            actionSpan.innerHTML = '<span class="icon-[tabler--check] w-4 h-4 inline-block"></span>';
            actionSpan.setAttribute('title', SUCCESS_TEXT);
            actionSpan.setAttribute('aria-label', SUCCESS_TEXT);
          }

          btn.classList.add('bg-lime-50', 'border-lime-500');

          setTimeout(() => {
            if (actionSpan) {
              actionSpan.innerHTML = originalInnerHTML;
              actionSpan.setAttribute('title', originalTitle);
              actionSpan.setAttribute('aria-label', originalTitle);
              actionSpan.className = originalClasses;
            }
            btn.classList.remove('bg-lime-50', 'border-lime-500');
          }, 2000);
        } catch (err) {
          alert(ERROR_TEXT);
          if (actionSpan) {
            actionSpan.innerHTML = originalInnerHTML || '<span class="icon-[tabler--copy] w-4 h-4 inline-block"></span>';
            actionSpan.className = originalClasses;
          }
        }
      });
    });
  </script>
</section>