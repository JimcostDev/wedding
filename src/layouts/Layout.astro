---
interface Props {
  wedding?: {
    hero?: Record<string, unknown>;
    footer?: Record<string, unknown>;
    layout?: {
      htmlLang?: string;
      meta?: {
        ogLocale?: string;
        ogSiteName?: string;
        favicon?: { src?: string; type?: string; sizes?: string };
        appleTouchIcon?: string;
      };
      defaultProps?: {
        title?: string;
        description?: string;
        canonical?: string;
        ogImage?: string;
      };
      pageTitle?: {
        suffix?: string;
      };
      schemaOrg?: Record<string, unknown>;
    };
  };
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

import '@styles/global.css';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

const {
  wedding,
  title = "You're My Penguin",
  description = 'Acompáñanos en la celebración de nuestra boda. Aquí encontrarás toda la información importante sobre el evento, ubicación, itinerario y podrás confirmar tu asistencia.',
  canonical = 'https://alexa-jois.vercel.app',
  ogImage = '/banner-boda.jpeg',
} = Astro.props;

const weddingLayout = wedding?.layout;
const weddingMeta = weddingLayout?.meta;

const resolvedDescription =
  Astro.props.description ?? weddingLayout?.defaultProps?.description ?? description;
const resolvedCanonical =
  Astro.props.canonical ?? weddingLayout?.defaultProps?.canonical ?? canonical;
const resolvedOgImage =
  Astro.props.ogImage ?? weddingLayout?.defaultProps?.ogImage ?? ogImage;

const resolvedTitlePrefix = Astro.props.title ?? title;
const resolvedTitleSuffix = weddingLayout?.pageTitle?.suffix ?? 'Paula ❤️ Ronaldo';
const pageTitle = weddingLayout?.pageTitle?.suffix
  ? `${resolvedTitlePrefix}: ${resolvedTitleSuffix}`
  : resolvedTitlePrefix;

const schemaOrg = weddingLayout?.schemaOrg
  ? { ...weddingLayout.schemaOrg, image: weddingLayout.schemaOrg.image ?? resolvedOgImage }
  : null;

const resolvedHtmlLang = weddingLayout?.htmlLang ?? 'es';
const resolvedMetaOgLocale = weddingMeta?.ogLocale ?? 'es_ES';
const resolvedMetaOgSiteName = weddingMeta?.ogSiteName ?? 'Paula & Ronaldo';
const resolvedFavicon = weddingMeta?.favicon?.src ?? '/you-are-my-penguin.png';
const resolvedFaviconType = weddingMeta?.favicon?.type ?? 'image/webp';
const resolvedFaviconSizes = weddingMeta?.favicon?.sizes ?? 'any';
const resolvedAppleTouchIcon = weddingMeta?.appleTouchIcon ?? '/you-are-my-penguin.png';
---

<!doctype html>
<html lang={resolvedHtmlLang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow" />
    <meta name="language" content="Spanish" />

    <title>{pageTitle}</title>
    <meta name="description" content={resolvedDescription} />
    <link rel="canonical" href={resolvedCanonical} />
    
    <link rel="icon" type={resolvedFaviconType} href={resolvedFavicon} sizes={resolvedFaviconSizes} />
    <link rel="apple-touch-icon" href={resolvedAppleTouchIcon} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:locale" content={resolvedMetaOgLocale} />
    <meta property="og:site_name" content={resolvedMetaOgSiteName} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={resolvedOgImage} />

    {schemaOrg && (
      <script type="application/ld+json">
        {JSON.stringify(schemaOrg)}
      </script>
    )}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Montserrat:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">

    <ClientRouter />
  </head>

  <body class="bg-slate-50 text-stone-800 antialiased font-sans">
    <a 
      href="#main-content" 
      class="sr-only focus:not-sr-only focus:fixed top-4 left-4 bg-rose-600 text-white px-4 py-2 rounded-lg z-50 font-medium shadow-lg"
    >
      Saltar al contenido principal
    </a>

    <Header hero={wedding?.hero} />

    <main id="main-content" class="w-full">
      <slot />
    </main>

    <Footer footer={wedding?.footer} />
  </body>
</html>